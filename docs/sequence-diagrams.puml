@startuml(UC01_Xem_danh_sach_Model_trong_kho)
!theme plain
title UC01 - Xem danh sách Model trong kho

actor User
participant "RequestDevicePage" as Page
participant "RequestDeviceViewModel" as VM
participant "GetDeviceModelsUseCase" as UC
participant "DeviceModelRepository" as Repo
database "SQLite" as DB

User -> Page: Mở trang
activate Page
Page -> VM: Load danh sách
activate VM
VM -> UC: Lấy danh sách có phân trang
activate UC
UC -> Repo: Truy vấn theo trang và kích thước
activate Repo
Repo -> DB: Thực thi truy vấn SELECT
DB --> Repo: Trả về dòng dữ liệu
Repo --> UC: PagedResult
deactivate Repo
UC --> VM: Dữ liệu danh sách
deactivate UC
VM --> Page: Gán Items, PageNumbers
deactivate VM
Page --> User: Render DataGrid và thanh phân trang
deactivate Page
@enduml

