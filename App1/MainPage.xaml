<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App1.BlankPage1"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App1"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:primitives="using:CommunityToolkit.WinUI.UI.Controls.Primitives"
    
    mc:Ignorable="d">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#566B7F" Height="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Title -->
            <TextBlock
       Grid.Column="0"
       Margin="8,0,0,0"
       VerticalAlignment="Center"
       Foreground="White"
       FontWeight="Bold">
       Borrow Model
            </TextBlock>

            <!-- Close Button -->
            <Button
       Grid.Column="1"
       Width="40"
       Height="40">
                <FontIcon Glyph="&#xE711;" />
            </Button>
        </Grid>
        <Grid Grid.Row="1"
             Background="#F0F0F0">
            <StackPanel
              
               >
                <Border
    Margin="50"
    Background="#FFFFFF" 
    CornerRadius="9"
    >
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel
            Grid.Column="0">
                            <StackPanel
                Margin="15,5,0,0">
                                <TextBlock>Inventory</TextBlock>
                                <ComboBox>
                                    <ComboBoxItem>PM P/Technology Strategy G</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel
                Margin="15,5,0,0">
                                <TextBlock>Address</TextBlock>
                                <TextBox 
                    Text="2F Room Device"
                    IsEnabled="False"></TextBox>
                            </StackPanel>

                            <StackPanel
                 Margin="15,5,0,0">
                                <TextBlock>Number</TextBlock>
                                <ComboBox>
                                    <ComboBoxItem>1</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>

                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <StackPanel
                 Margin="0,5,0,0">
                                <TextBlock>Address</TextBlock>
                                <TextBox 
                     Text="2F Room Device"
                     IsEnabled="False"></TextBox>
                            </StackPanel>
                        </StackPanel>

                    </Grid>
                </Border>

                <StackPanel
                   HorizontalAlignment="Right"
                   Orientation="Horizontal"
                   >
                    <Button
                  
                     Margin="0,0,20,0"
                     Content="Cancel"
                     ></Button>

                    <Button
            
                     Margin="0,0,10,0"
                     Content="Ok"
                     ></Button>

                </StackPanel>

            </StackPanel>



        </Grid>


    </Grid>

</Page>
