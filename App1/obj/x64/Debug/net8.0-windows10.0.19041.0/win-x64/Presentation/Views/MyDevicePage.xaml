<?xml version="1.0" encoding="utf-8" ?>
<Page x:ConnectionId='1'
    x:Class="App1.Presentation.Views.MyDevicePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:primitives="using:CommunityToolkit.WinUI.UI.Controls.Primitives"
                        >

    <Page.Resources>
        <Style x:Key="WrapCellStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
    </Page.Resources>

    <Grid Padding="20" RowDefinitions="Auto,Auto,*,Auto">

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,12"
            FontSize="24"
            FontWeight="Bold"
            Text="My Devices" />

        <Button x:ConnectionId='2'
            x:Name="ReturnSelectedBtn"
            Grid.Row="1"
            Margin="0,0,0,8"
                                        
            Content="Return Selected"
            IsEnabled="False" />

        <controls:DataGrid x:ConnectionId='3'
            x:Name="DeviceDataGrid"
            Grid.Row="2"
            AutoGenerateColumns="False"
            CanUserSortColumns="True"
            CanUserResizeColumns="True"
            ColumnHeaderHeight="86"
            GridLinesVisibility="All"
            HorizontalGridLinesBrush="#DEDEDE"
            IsReadOnly="True"
                                            
                                      
            VerticalGridLinesBrush="#DEDEDE"
            HorizontalScrollBarVisibility="Visible"
            VerticalScrollBarVisibility="Auto">

            <controls:DataGrid.Columns>
                <!-- CheckBox -->
                <controls:DataGridTemplateColumn Width="45" MinWidth="45" CanUserResize="False">
                    <controls:DataGridTemplateColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <CheckBox x:ConnectionId='30' Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                              />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="#F5F5F5" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTemplateColumn.HeaderStyle>
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox x:ConnectionId='31' IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      MinWidth="0" Padding="0"
                                                                />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

                <!-- Model Name -->
                <controls:DataGridTextColumn Binding="{Binding ModelName}" Width="2.5*" MinWidth="140"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Model Name" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid x:ConnectionId='27' Grid.Row="2" Padding="4,0" Background="#F5F5F5"                                           >
                                                <TextBox x:ConnectionId='28' VerticalAlignment="Center" PlaceholderText="Filter..." Tag="ModelName"                                         />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- IMEI -->
                <controls:DataGridTextColumn Binding="{Binding IMEI}" Width="2*" MinWidth="110"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="IMEI" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="#F5F5F5" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Label -->
                <controls:DataGridTextColumn Binding="{Binding Label}" Width="1.5*" MinWidth="80"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Label" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="#F5F5F5" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Serial Number -->
                <controls:DataGridTextColumn Binding="{Binding SerialNumber}" Width="2*" MinWidth="110"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Serial Number" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="#F5F5F5" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Circuit Serial Number -->
                <controls:DataGridTextColumn Binding="{Binding CircuitSerialNumber}" Width="2*" MinWidth="110"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Circuit S/N" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="#F5F5F5" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- H/W Version -->
                <controls:DataGridTextColumn Binding="{Binding HWVersion}" Width="1*" MinWidth="70"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="H/W Ver." />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="#F5F5F5" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Borrowed Date -->
                <controls:DataGridTextColumn Binding="{Binding BorrowedDate}" Width="1.5*" MinWidth="100"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Borrowed Date" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="#F5F5F5" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Return Date -->
                <controls:DataGridTextColumn Binding="{Binding ReturnDate}" Width="1.5*" MinWidth="100"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Return Date" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="#F5F5F5" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Invoice -->
                <controls:DataGridTextColumn Binding="{Binding Invoice}" Width="1*" MinWidth="70"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Invoice" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="#F5F5F5" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Status -->
                <controls:DataGridTextColumn Binding="{Binding Status}" Width="1.2*" MinWidth="80"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Status" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid x:ConnectionId='16' Grid.Row="2" Padding="4,0" Background="#F5F5F5"                                           >
                                                <ComboBox x:ConnectionId='17' HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                                          PlaceholderText="-- All --"
                                                                                        
                                                                                                            >
                                                    <ComboBoxItem Content="-- All --" Tag="" />
                                                    <ComboBoxItem Content="Occupied" Tag="Occupied" />
                                                </ComboBox>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Inventory + Clear Filter -->
                <controls:DataGridTextColumn Binding="{Binding Inventory}" Width="1.2*" MinWidth="80"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Inventory" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid x:ConnectionId='13' Grid.Row="2" Padding="4,0" Background="#F5F5F5"                                           >
                                                <Button x:ConnectionId='14' HorizontalAlignment="Stretch" VerticalAlignment="Center" Content="Clear Filter"                           />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>
            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <!-- Pagination Bar -->
        <Grid Grid.Row="3" Margin="0,8,0,0" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                <TextBlock x:ConnectionId='10' x:Name="ShowingText" VerticalAlignment="Center" />
                <TextBlock Text="  |  Rows per page:" VerticalAlignment="Center" Margin="8,0,4,0" />
                <ComboBox x:ConnectionId='11' x:Name="PageSizeComboBox" VerticalAlignment="Center"                                                      Width="80">
                    <ComboBoxItem Content="10" Tag="10" />
                    <ComboBoxItem Content="25" Tag="25" />
                    <ComboBoxItem Content="50" Tag="50" IsSelected="True" />
                    <ComboBoxItem Content="100" Tag="100" />
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <Button x:ConnectionId='4' Content="First"                         x:Name="FirstBtn" />
                <Button x:ConnectionId='5' Content="Previous"                        x:Name="PrevBtn" />
                <ItemsRepeater x:ConnectionId='6' x:Name="PageNumbersRepeater"                                                    >
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Horizontal" Spacing="2" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Button x:ConnectionId='9' MinWidth="36" MinHeight="36" HorizontalAlignment="Center"
                                                             Content="{Binding DisplayText}"
                                    CornerRadius="18"
                                    IsEnabled="{Binding IsClickable}" />
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
                <Button x:ConnectionId='7' Content="Next"                        x:Name="NextBtn" />
                <Button x:ConnectionId='8' Content="Last"                        x:Name="LastBtn" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>

