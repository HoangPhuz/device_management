<?xml version="1.0" encoding="utf-8" ?>
<Page x:ConnectionId='1'
    x:Class="App1.Presentation.Views.RequestDevicePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:primitives="using:CommunityToolkit.WinUI.UI.Controls.Primitives"
                        >

    <Page.Resources>
        <Style x:Key="WrapCellStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
    </Page.Resources>

    <Grid Padding="20" RowDefinitions="Auto,*,Auto">

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,12"
            FontSize="24"
            FontWeight="Bold"
            Text="Model List" />

        <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="2">
            <controls:DataGrid x:ConnectionId='10'
            x:Name="ModelDataGrid"
            AutoGenerateColumns="False"
            CanUserSortColumns="True"
            ColumnHeaderHeight="86"
            GridLinesVisibility="All"
            HorizontalGridLinesBrush="#DEDEDE"
            IsReadOnly="True"
                                            
                                      
            VerticalGridLinesBrush="#DEDEDE">

            <controls:DataGrid.Columns>
                <!-- Model -->
                <controls:DataGridTextColumn Binding="{Binding Model}" Width="*"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Model" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid x:ConnectionId='27' Grid.Row="2" Padding="4,0" Background="#F5F5F5"                                           >
                                                <TextBox x:ConnectionId='28' VerticalAlignment="Center" PlaceholderText="Model" Tag="Model"                                         />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Manufacturer -->
                <controls:DataGridTextColumn Binding="{Binding Manufacturer}" Width="*"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Manufacturer" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid x:ConnectionId='24' Grid.Row="2" Padding="4,0" Background="#F5F5F5"                                           >
                                                <TextBox x:ConnectionId='25' VerticalAlignment="Center" PlaceholderText="Manufacturer" Tag="Manufacturer"                                         />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Category -->
                <controls:DataGridTextColumn Binding="{Binding Category}" Width="*"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Category" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid x:ConnectionId='21' Grid.Row="2" Padding="4,0" Background="#F5F5F5"                                           >
                                                <ComboBox x:ConnectionId='22' HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                                          PlaceholderText="-- All --"
                                                                                          
                                                                                                               />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Sub Category -->
                <controls:DataGridTextColumn Binding="{Binding SubCategory}" Width="*"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Sub Category" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid x:ConnectionId='18' Grid.Row="2" Padding="4,0" Background="#F5F5F5"                                           >
                                                <ComboBox x:ConnectionId='19' HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                                          PlaceholderText="-- All --"
                                                                                             
                                                                                                                  />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Available -->
                <controls:DataGridTextColumn Binding="{Binding Available}" Width="100"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Available" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="#F5F5F5" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Reserved -->
                <controls:DataGridTextColumn Binding="{Binding Reserved}" Width="100"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Reserved" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="#F5F5F5" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Function -->
                <controls:DataGridTemplateColumn Width="140">
                    <controls:DataGridTemplateColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Function" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid x:ConnectionId='12' Grid.Row="2" Padding="4,0" Background="#F5F5F5"                                           >
                                                <Button x:ConnectionId='13' HorizontalAlignment="Stretch" VerticalAlignment="Center" Content="Clear Filter"                           />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTemplateColumn.HeaderStyle>
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button x:ConnectionId='14' Content="Borrow"                           
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    IsEnabled="{Binding Available, Converter={StaticResource AvailableToBoolConverter}}" />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
            </controls:DataGrid.Columns>
        </controls:DataGrid>
        </Border>

        <!-- Pagination Bar -->
        <Grid Grid.Row="2" Margin="0,8,0,0" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                <TextBlock x:ConnectionId='8' x:Name="ShowingText" VerticalAlignment="Center" />
                <TextBlock Text="  |  Rows per page:" VerticalAlignment="Center" Margin="8,0,4,0" />
                <ComboBox x:ConnectionId='9' x:Name="PageSizeComboBox" VerticalAlignment="Center"                                                      Width="80">
                    <ComboBoxItem Content="10" Tag="10" />
                    <ComboBoxItem Content="25" Tag="25" />
                    <ComboBoxItem Content="50" Tag="50" IsSelected="True" />
                    <ComboBoxItem Content="100" Tag="100" />
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <Button x:ConnectionId='2' Content="First"                         x:Name="FirstBtn" />
                <Button x:ConnectionId='3' Content="Previous"                        x:Name="PrevBtn" />
                <ItemsRepeater x:ConnectionId='4' x:Name="PageNumbersRepeater"                                                    >
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Horizontal" Spacing="2" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Button x:ConnectionId='7' MinWidth="36" MinHeight="36" HorizontalAlignment="Center"
                                                             Content="{Binding DisplayText}"
                                    CornerRadius="18"
                                    IsEnabled="{Binding IsClickable}" />
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
                <Button x:ConnectionId='5' Content="Next"                        x:Name="NextBtn" />
                <Button x:ConnectionId='6' Content="Last"                        x:Name="LastBtn" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>

