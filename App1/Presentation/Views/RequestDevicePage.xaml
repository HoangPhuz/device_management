<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="App1.Presentation.Views.RequestDevicePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:primitives="using:CommunityToolkit.WinUI.UI.Controls.Primitives"
    Loaded="Page_Loaded">

    <Page.Resources>
        <Style x:Key="WrapCellStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
    </Page.Resources>

    <Grid Padding="20" RowDefinitions="Auto,*,Auto">

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,12"
            FontSize="24"
            FontWeight="Bold"
            Text="Model List" />

        <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="2">
            <controls:DataGrid
            x:Name="ModelDataGrid"
            AutoGenerateColumns="False"
            CanUserSortColumns="True"
            ColumnHeaderHeight="86"
            GridLinesVisibility="All"
            HorizontalGridLinesBrush="#DEDEDE"
            IsReadOnly="True"
            LoadingRow="DataGrid_LoadingRow"
            Sorting="DataGrid_Sorting"
            VerticalGridLinesBrush="#DEDEDE">

            <controls:DataGrid.Columns>
                <!-- Model -->
                <controls:DataGridTextColumn Binding="{Binding Model}" Width="*"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Model" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Padding="4,0" Background="#F5F5F5" PointerPressed="FilterArea_PointerPressed">
                                                <TextBox VerticalAlignment="Center" PlaceholderText="Model" Tag="Model" TextChanged="FilterTextBox_TextChanged" />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Manufacturer -->
                <controls:DataGridTextColumn Binding="{Binding Manufacturer}" Width="*"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Manufacturer" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Padding="4,0" Background="#F5F5F5" PointerPressed="FilterArea_PointerPressed">
                                                <TextBox VerticalAlignment="Center" PlaceholderText="Manufacturer" Tag="Manufacturer" TextChanged="FilterTextBox_TextChanged" />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Category -->
                <controls:DataGridTextColumn Binding="{Binding Category}" Width="*"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Category" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Padding="4,0" Background="#F5F5F5" PointerPressed="FilterArea_PointerPressed">
                                                <ComboBox HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                                          PlaceholderText="-- All --"
                                                          Loaded="CategoryComboBox_Loaded"
                                                          SelectionChanged="CategoryComboBox_SelectionChanged" />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Sub Category -->
                <controls:DataGridTextColumn Binding="{Binding SubCategory}" Width="*"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Sub Category" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Padding="4,0" Background="#F5F5F5" PointerPressed="FilterArea_PointerPressed">
                                                <ComboBox HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                                          PlaceholderText="-- All --"
                                                          Loaded="SubCategoryComboBox_Loaded"
                                                          SelectionChanged="SubCategoryComboBox_SelectionChanged" />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Available -->
                <controls:DataGridTextColumn Binding="{Binding Available}" Width="100"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Available" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="#F5F5F5" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Reserved -->
                <controls:DataGridTextColumn Binding="{Binding Reserved}" Width="100"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Reserved" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="#F5F5F5" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Function -->
                <controls:DataGridTemplateColumn Width="140">
                    <controls:DataGridTemplateColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Text="Function" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Padding="4,0" Background="#F5F5F5" PointerPressed="FilterArea_PointerPressed">
                                                <Button HorizontalAlignment="Stretch" VerticalAlignment="Center" Content="Clear Filter" Click="ClearFilter_Click" />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTemplateColumn.HeaderStyle>
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Borrow" Click="BorrowButton_Click"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    IsEnabled="{Binding Available, Converter={StaticResource AvailableToBoolConverter}}" />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>
            </controls:DataGrid.Columns>
        </controls:DataGrid>
        </Border>

        <!-- Pagination Bar -->
        <Grid Grid.Row="2" Margin="0,8,0,0" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                <TextBlock x:Name="ShowingText" VerticalAlignment="Center" />
                <TextBlock Text="  |  Rows per page:" VerticalAlignment="Center" Margin="8,0,4,0" />
                <ComboBox x:Name="PageSizeComboBox" VerticalAlignment="Center" SelectionChanged="PageSizeComboBox_SelectionChanged" Width="80">
                    <ComboBoxItem Content="10" Tag="10" />
                    <ComboBoxItem Content="25" Tag="25" />
                    <ComboBoxItem Content="50" Tag="50" IsSelected="True" />
                    <ComboBoxItem Content="100" Tag="100" />
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <Button Content="First" Click="FirstPage_Click" x:Name="FirstBtn" />
                <Button Content="Previous" Click="PrevPage_Click" x:Name="PrevBtn" />
                <ItemsRepeater x:Name="PageNumbersRepeater" ItemsSource="{x:Bind _vm.PageNumbers, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Horizontal" Spacing="2" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Button MinWidth="36" MinHeight="36" HorizontalAlignment="Center"
                                    Click="PageNumber_Click" Content="{Binding DisplayText}"
                                    CornerRadius="18"
                                    IsEnabled="{Binding IsClickable}" />
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
                <Button Content="Next" Click="NextPage_Click" x:Name="NextBtn" />
                <Button Content="Last" Click="LastPage_Click" x:Name="LastBtn" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
