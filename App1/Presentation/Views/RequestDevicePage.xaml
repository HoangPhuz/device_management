<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="App1.Presentation.Views.RequestDevicePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:primitives="using:CommunityToolkit.WinUI.UI.Controls.Primitives"
    xmlns:conv="using:App1.Presentation.Converters"
    Loaded="Page_Loaded">

    <Page.Resources>
        <SolidColorBrush x:Key="PositiveCountBrush" Color="#3276B1" />
        <SolidColorBrush x:Key="NonPositiveCountBrush" Color="#333333" />
        <conv:PositiveIntToBrushConverter
            x:Key="PositiveIntToBrushConverter"
            PositiveBrush="{StaticResource PositiveCountBrush}"
            NonPositiveBrush="{StaticResource NonPositiveCountBrush}" />

        <SolidColorBrush x:Key="CurrentPageBgBrush" Color="#5E8283" />
        <SolidColorBrush x:Key="CurrentPageFgBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="NormalPageBgBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="NormalPageFgBrush" Color="#2C2C2C" />

        <conv:BoolToBrushConverter
            x:Key="IsCurrentToBackgroundBrushConverter"
            TrueBrush="{StaticResource CurrentPageBgBrush}"
            FalseBrush="{StaticResource NormalPageBgBrush}" />
        <conv:BoolToBrushConverter
            x:Key="IsCurrentToForegroundBrushConverter"
            TrueBrush="{StaticResource CurrentPageFgBrush}"
            FalseBrush="{StaticResource NormalPageFgBrush}" />

        <Style x:Key="WrapCellStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
        <Style x:Key="ModelCellStyle" BasedOn="{StaticResource WrapCellStyle}" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#3276B1" />
        </Style>
    </Page.Resources>

    <Grid Padding="20" RowDefinitions="Auto,Auto,*,Auto">

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,12"
            FontSize="24"
            FontWeight="Bold"
            Text="Models List" />

        <!-- Toolbar: Rows per page -->
        <Grid Grid.Row="1" Margin="0,0,0,10" >
            <StackPanel
                Margin="0,0,25,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    Margin="0,0,8,0"
                    Content="Rows per page"
                    Foreground="Black"
                    IsEnabled="False" />
                <ComboBox
                    x:Name="PageSizeComboBox"
                    Width="70"
                    SelectionChanged="PageSizeComboBox_SelectionChanged">
                    <ComboBoxItem Content="10" Tag="10" />
                    <ComboBoxItem Content="25" Tag="25" />
                    <ComboBoxItem Content="50" Tag="50" IsSelected="True" />
                    <ComboBoxItem Content="100" Tag="100" />
                </ComboBox>
            </StackPanel>
        </Grid>

        <controls:DataGrid
            Grid.Row="2"
            x:Name="ModelDataGrid"
            AutoGenerateColumns="False"
            BorderThickness="0"
            CornerRadius="2"
            CanUserSortColumns="True"
            ColumnHeaderHeight="86"
            GridLinesVisibility="All"
            HorizontalGridLinesBrush="#DEDEDE"
            VerticalGridLinesBrush="#DEDEDE"
            IsReadOnly="True"
            LoadingRow="DataGrid_LoadingRow"
            Sorting="DataGrid_Sorting"
            >

            <controls:DataGrid.CellStyle>
                <Style TargetType="controls:DataGridCell">
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                </Style>
            </controls:DataGrid.CellStyle>

            <controls:DataGrid.Columns>
                <!-- Name -->
                <controls:DataGridTextColumn Binding="{Binding Name}" Width="*"
                                             ElementStyle="{StaticResource ModelCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#337F94" Text="Name" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Padding="4,0" Background="White" PointerPressed="FilterArea_PointerPressed">
                                                <TextBox VerticalAlignment="Center" PlaceholderText="Name" Tag="Name" TextChanged="FilterTextBox_TextChanged" />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Manufacturer -->
                <controls:DataGridTextColumn Binding="{Binding Manufacturer}" Width="*"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#337F94" Text="Manufacturer" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Padding="4,0" Background="White" PointerPressed="FilterArea_PointerPressed">
                                                <TextBox VerticalAlignment="Center" PlaceholderText="Manufacturer" Tag="Manufacturer" TextChanged="FilterTextBox_TextChanged" />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Category -->
                <controls:DataGridTextColumn Binding="{Binding Category}" Width="*"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#337F94" Text="Category" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Padding="4,0" Background="White" PointerPressed="FilterArea_PointerPressed">
                                                <ComboBox HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                                          PlaceholderText="-- All --"
                                                          Loaded="CategoryComboBox_Loaded"
                                                          SelectionChanged="CategoryComboBox_SelectionChanged" />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Sub Category -->
                <controls:DataGridTextColumn Binding="{Binding SubCategory}" Width="*"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#337F94" Text="Sub Category" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Padding="4,0" Background="White" PointerPressed="FilterArea_PointerPressed">
                                                <ComboBox HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                                          PlaceholderText="-- All --"
                                                          Loaded="SubCategoryComboBox_Loaded"
                                                          SelectionChanged="SubCategoryComboBox_SelectionChanged" />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Available -->
                <controls:DataGridTemplateColumn Width="100">
                    <controls:DataGridTemplateColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#337F94" Text="Available" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="White" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTemplateColumn.HeaderStyle>
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                FontWeight="Bold"
                                Style="{StaticResource WrapCellStyle}"
                                Text="{Binding Available}"
                                Foreground="{Binding Available, Converter={StaticResource PositiveIntToBrushConverter}}" />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

                <!-- Reserved -->
                <controls:DataGridTemplateColumn Width="100">
                    <controls:DataGridTemplateColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#337F94" Text="Reserved" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="White" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTemplateColumn.HeaderStyle>
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                FontWeight="Bold"
                                Style="{StaticResource WrapCellStyle}"
                                Text="{Binding Reserved}"
                                Foreground="{Binding Reserved, Converter={StaticResource PositiveIntToBrushConverter}}" />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

                    <!-- Function -->
                    <controls:DataGridTemplateColumn Width="*">
                        <controls:DataGridTemplateColumn.HeaderStyle>
                            <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                                <Setter Property="ContentTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="40" />
                                                    <RowDefinition Height="1" />
                                                    <RowDefinition Height="45" />
                                                </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#337F94" Text="Function" />
                                                <Rectangle Grid.Row="1" Fill="LightGray" />
                                                <Grid Grid.Row="2" Padding="4,0" Background="White" PointerPressed="FilterArea_PointerPressed">
                                                    <Button
                                                        BorderThickness="0"
                                                        Foreground="#429CB6"
                                                        MinWidth="100"
                                                        MinHeight="36"
                                                        CornerRadius="8"
                                                        Padding="12,8"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        Content="Clear Filter"
                                                        Click="ClearFilter_Click">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border
                                                                                x:Name="ClearFilterBorder"
                                                                                Background="Transparent"
                                                                                CornerRadius="8"
                                                                                BorderThickness="1"
                                                                                >
                                                                                <TextBlock
                                                                                    x:Name="ContentText"
                                                                                    Text="{TemplateBinding Content}"
                                                                                    Foreground="{TemplateBinding Foreground}"
                                                                                    HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Center"
                                                                                    Padding="12,8"/>
                                                                                <VisualStateManager.VisualStateGroups>
                                                                                    <VisualStateGroup x:Name="CommonStates">
                                                                                        <VisualState x:Name="Normal"/>
                                                                                        <VisualState x:Name="PointerOver">
                                                                                            <Storyboard>
                                                                                                <ColorAnimation
                                                                                                    Storyboard.TargetName="ClearFilterBorder"
                                                                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                                                    To="#429CB6"
                                                                                                    Duration="0"/>
                                                                                                <ColorAnimation
                                                                                                    Storyboard.TargetName="ContentText"
                                                                                                    Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                                                                                    To="White"
                                                                                                    Duration="0"/>
                                                                                            </Storyboard>
                                                                                        </VisualState>
                                                                                        <VisualState x:Name="Pressed">
                                                                                            <Storyboard>
                                                                                                <DoubleAnimation
                                                                                                    Storyboard.TargetName="ContentText"
                                                                                                    Storyboard.TargetProperty="Opacity"
                                                                                                    To="0.7"
                                                                                                    Duration="0"/>
                                                                                            </Storyboard>
                                                                                        </VisualState>
                                                                                        <VisualState x:Name="Disabled">
                                                                                            <Storyboard>
                                                                                                <DoubleAnimation
                                                                                                    Storyboard.TargetName="ContentText"
                                                                                                    Storyboard.TargetProperty="Opacity"
                                                                                                    To="0.5"
                                                                                                    Duration="0"/>
                                                                                            </Storyboard>
                                                                                        </VisualState>
                                                                                    </VisualStateGroup>
                                                                                </VisualStateManager.VisualStateGroups>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </Grid>
                                            </Grid>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </controls:DataGridTemplateColumn.HeaderStyle>

                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button
                                    FontSize="16"
                                    CornerRadius="8"
                                    MinWidth="100"
                                    MinHeight="36"
                                    Background="Transparent"
                                    Click="BorrowButton_Click"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    IsEnabled="{Binding Available, Converter={StaticResource AvailableToBoolConverter}}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border
                                                            x:Name="BorrowBorder"
                                                            Background="Transparent"
                                                            CornerRadius="8"
                                                            BorderThickness="1"
                                                            >
                                                            <StackPanel
                                                                Orientation="Horizontal"
                                                                Spacing="6"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Padding="12,8">
                                                                <!-- Android SVG Path inline -->
                                                                <Viewbox Width="18" Height="18" VerticalAlignment="Center">
                                                                    <Path
                                                                        x:Name="AndroidIcon"
                                                                        Data="M5 8 C5 4.13 8.13 1 12 1 C15.87 1 19 4.13 19 8 Z
                                                                              M6 18 L6 22 C6 22.552 6.448 23 7 23
                                                                              C7.552 23 8 22.552 8 22 L8 18 Z
                                                                              M16 18 L16 22 C16 22.552 16.448 23 17 23
                                                                              C17.552 23 18 22.552 18 22 L18 18 Z
                                                                              M2 9 C2 8.448 2.448 8 3 8
                                                                              C3.552 8 4 8.448 4 9 L4 16
                                                                              C4 16.552 3.552 17 3 17
                                                                              C2.448 17 2 16.552 2 16 Z
                                                                              M20 9 C20 8.448 20.448 8 21 8
                                                                              C21.552 8 22 8.448 22 9 L22 16
                                                                              C22 16.552 21.552 17 21 17
                                                                              C20.448 17 20 16.552 20 16 Z
                                                                              M5 8 L5 17 C5 17.552 5.448 18 6 18
                                                                              L18 18 C18.552 18 19 17.552 19 17
                                                                              L19 8 Z
                                                                              M9.5 5 C9.5 4.724 9.724 4.5 10 4.5
                                                                              C10.276 4.5 10.5 4.724 10.5 5
                                                                              C10.5 5.276 10.276 5.5 10 5.5
                                                                              C9.724 5.5 9.5 5.276 9.5 5 Z
                                                                              M13.5 5 C13.5 4.724 13.724 4.5 14 4.5
                                                                              C14.276 4.5 14.5 4.724 14.5 5
                                                                              C14.5 5.276 14.276 5.5 14 5.5
                                                                              C13.724 5.5 13.5 5.276 13.5 5 Z
                                                                              M8.293 2.293 L6.293 4.293
                                                                              C6.098 4.488 6.098 4.805 6.293 5
                                                                              C6.488 5.195 6.805 5.195 7 5
                                                                              L9 3 C9.195 2.805 9.195 2.488 9 2.293
                                                                              C8.805 2.098 8.488 2.098 8.293 2.293 Z
                                                                              M15.707 2.293 C15.512 2.098 15.195 2.098 15 2.293
                                                                              C14.805 2.488 14.805 2.805 15 3
                                                                              L17 5 C17.195 5.195 17.512 5.195 17.707 5
                                                                              C17.902 4.805 17.902 4.488 17.707 4.293 Z"
                                                                        Stretch="Uniform"
                                                                        Width="18"
                                                                        Height="18">    
                                                                        <Path.Fill>
                                                                            <SolidColorBrush x:Name="AndroidIconFill" Color="#54B07D"/>
                                                                        </Path.Fill>
                                                                    </Path>
                                                                </Viewbox>

                                                                <TextBlock
                                                                    x:Name="BorrowText"
                                                                    Text="Borrow"
                                                                    Foreground="#54B07D"
                                                                    VerticalAlignment="Center"/>
                                                            </StackPanel>

                                                            <VisualStateManager.VisualStateGroups>
                                                                <VisualStateGroup x:Name="CommonStates">
                                                                    <VisualState x:Name="Normal"/>
                                                                    <VisualState x:Name="PointerOver">
                                                                        <Storyboard>
                                                                            <ColorAnimation
                                                                                Storyboard.TargetName="BorrowBorder"
                                                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                                To="#54B07D" Duration="0"/>
                                                                                                    <ColorAnimation
                                                                                Storyboard.TargetName="AndroidIconFill"
                                                                                Storyboard.TargetProperty="Color"
                                                                                To="White" Duration="0"/>
                                                                                                <ColorAnimation
                                                                                Storyboard.TargetName="BorrowText"
                                                                                Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                                                                To="White" Duration="0"/>           
                                                                        </Storyboard>
                                                                    </VisualState>
                                                                    <VisualState x:Name="Pressed">
                                                                        <Storyboard>
                                                                            <DoubleAnimation
                                                                                Storyboard.TargetName="BorrowBorder"
                                                                                Storyboard.TargetProperty="Opacity"
                                                                                To="0.7" Duration="0"/>
                                                                                                </Storyboard>
                                                                                            </VisualState>
                                                                                            <VisualState x:Name="Disabled">
                                                                                                <Storyboard>
                                                                                                    <DoubleAnimation
                                                                                Storyboard.TargetName="BorrowBorder"
                                                                                Storyboard.TargetProperty="Opacity"
                                                                                To="0.5" Duration="0"/>
                                                                        </Storyboard>
                                                                    </VisualState>
                                                                </VisualStateGroup>
                                                            </VisualStateManager.VisualStateGroups>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>
                </controls:DataGrid.Columns>
        </controls:DataGrid>

        
        

        <Border Grid.Row="3" Background="#ccc"  Padding="8,6" >
            <!-- Pagination Bar -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                    <TextBlock x:Name="ShowingText" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="First" Click="FirstPage_Click" x:Name="FirstBtn" CornerRadius="15" Padding="8,4" FontSize="12" />
                    <Button Content="Previous" Click="PrevPage_Click" x:Name="PrevBtn" CornerRadius="15" Padding="8,4" FontSize="12" />
                    <ItemsRepeater x:Name="PageNumbersRepeater" ItemsSource="{x:Bind _vm.PageNumbers, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout                               
                                Orientation="Horizontal" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    MinWidth="28" MinHeight="28"
                                    CornerRadius="14"
                                    Padding="4,2"
                                    Background="{Binding IsCurrent, Converter={StaticResource IsCurrentToBackgroundBrushConverter}}"
                                    IsHitTestVisible="{Binding IsClickable}"
                                    Tapped="PageNumber_Tapped">
                                    <TextBlock
                                        Text="{Binding DisplayText}"
                                        FontSize="12"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="{Binding IsCurrent, Converter={StaticResource IsCurrentToForegroundBrushConverter}}" />
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <Button Content="Next" Click="NextPage_Click" x:Name="NextBtn" CornerRadius="15" Padding="8,4" FontSize="12" />
                    <Button Content="Last" Click="LastPage_Click" x:Name="LastBtn" CornerRadius="15" Padding="8,4" FontSize="12" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
