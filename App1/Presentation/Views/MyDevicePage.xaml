<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="App1.Presentation.Views.MyDevicePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:primitives="using:CommunityToolkit.WinUI.UI.Controls.Primitives"
    Loaded="Page_Loaded">

    <Page.Resources>
        <Style x:Key="WrapCellStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
    </Page.Resources>

    <Grid Padding="20" RowDefinitions="Auto,Auto,*,Auto">

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,12"
            FontSize="24"
            FontWeight="Bold"
            Text="My Devices" />

        <Button
            x:Name="ReturnSelectedBtn"
            Grid.Row="1"
            Margin="0,0,0,8"
            Click="ReturnSelected_Click"
            Content="Return Selected"
            IsEnabled="False" />

        <controls:DataGrid
            x:Name="DeviceDataGrid"
            Grid.Row="2"
            AutoGenerateColumns="False"
            CanUserSortColumns="True"
            CanUserResizeColumns="True"
            ColumnHeaderHeight="86"
            GridLinesVisibility="All"
            HorizontalGridLinesBrush="#DEDEDE"
            IsReadOnly="True"
            LoadingRow="DataGrid_LoadingRow"
            Sorting="DataGrid_Sorting"
            VerticalGridLinesBrush="#DEDEDE"
            HorizontalScrollBarVisibility="Visible"
            VerticalScrollBarVisibility="Auto">

            <controls:DataGrid.Columns>
                <!-- CheckBox -->
                <controls:DataGridTemplateColumn Width="45" MinWidth="45" CanUserResize="False">
                    <controls:DataGridTemplateColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <CheckBox Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Click="SelectAll_Click" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="White" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTemplateColumn.HeaderStyle>
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      MinWidth="0" Padding="0"
                                      Click="RowCheckBox_Click" />
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

                <!-- Model Name -->
                <controls:DataGridTextColumn Binding="{Binding ModelName}" Width="2.5*" MinWidth="140"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#566b7f" Text="Model Name" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Padding="4,0" Background="White" PointerPressed="FilterArea_PointerPressed">
                                                <TextBox VerticalAlignment="Center" PlaceholderText="Filter..." Tag="ModelName" TextChanged="FilterTextBox_TextChanged" />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- IMEI -->
                <controls:DataGridTextColumn Binding="{Binding IMEI}" Width="2*" MinWidth="110"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#566b7f" Text="IMEI" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="White" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Label -->
                <controls:DataGridTextColumn Binding="{Binding Label}" Width="1.5*" MinWidth="80"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#566b7f" Text="Label" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="White" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Serial Number -->
                <controls:DataGridTextColumn Binding="{Binding SerialNumber}" Width="2*" MinWidth="110"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#566b7f" Text="Serial Number" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="White" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Circuit Serial Number -->
                <controls:DataGridTextColumn Binding="{Binding CircuitSerialNumber}" Width="2*" MinWidth="110"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#566b7f" Text="Circuit S/N" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="White" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- H/W Version -->
                <controls:DataGridTextColumn Binding="{Binding HWVersion}" Width="1*" MinWidth="70"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#566b7f" Text="H/W Ver." />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="White" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Borrowed Date -->
                <controls:DataGridTextColumn Binding="{Binding BorrowedDate}" Width="1.5*" MinWidth="100"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#566b7f" Text="Borrowed Date" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="White" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Return Date -->
                <controls:DataGridTextColumn Binding="{Binding ReturnDate}" Width="1.5*" MinWidth="100"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#566b7f" Text="Return Date" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="White" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Invoice -->
                <controls:DataGridTextColumn Binding="{Binding Invoice}" Width="1*" MinWidth="70"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#566b7f" Text="Invoice" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Background="White" />
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Status -->
                <controls:DataGridTextColumn Binding="{Binding Status}" Width="1.2*" MinWidth="80"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#566b7f" Text="Status" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Padding="4,0" Background="White" PointerPressed="FilterArea_PointerPressed">
                                                <ComboBox HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                                          PlaceholderText="-- All --"
                                                          Loaded="StatusComboBox_Loaded"
                                                          SelectionChanged="StatusComboBox_SelectionChanged">
                                                    <ComboBoxItem Content="-- All --" Tag="" />
                                                    <ComboBoxItem Content="Occupied" Tag="Occupied" />
                                                </ComboBox>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>

                <!-- Inventory + Clear Filter -->
                <controls:DataGridTextColumn Binding="{Binding Inventory}" Width="1.2*" MinWidth="80"
                                             ElementStyle="{StaticResource WrapCellStyle}">
                    <controls:DataGridTextColumn.HeaderStyle>
                        <Style BasedOn="{StaticResource BaseColHeaderStyle}" TargetType="primitives:DataGridColumnHeader">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="1" />
                                                <RowDefinition Height="45" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#566b7f" Text="Inventory" />
                                            <Rectangle Grid.Row="1" Fill="LightGray" />
                                            <Grid Grid.Row="2" Padding="4,0" Background="White" PointerPressed="FilterArea_PointerPressed">
                                                <Button HorizontalAlignment="Stretch" VerticalAlignment="Center" Content="Clear Filter" Click="ClearFilter_Click" />
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </controls:DataGridTextColumn.HeaderStyle>
                </controls:DataGridTextColumn>
            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <!-- Pagination Bar -->
        <Grid Grid.Row="3" Margin="0,8,0,0" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                <TextBlock x:Name="ShowingText" VerticalAlignment="Center" />
                <TextBlock Text="  |  Rows per page:" VerticalAlignment="Center" Margin="8,0,4,0" />
                <ComboBox x:Name="PageSizeComboBox" VerticalAlignment="Center" SelectionChanged="PageSizeComboBox_SelectionChanged" Width="80">
                    <ComboBoxItem Content="10" Tag="10" />
                    <ComboBoxItem Content="25" Tag="25" />
                    <ComboBoxItem Content="50" Tag="50" IsSelected="True" />
                    <ComboBoxItem Content="100" Tag="100" />
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <Button Content="First" Click="FirstPage_Click" x:Name="FirstBtn" />
                <Button Content="Previous" Click="PrevPage_Click" x:Name="PrevBtn" />
                <ItemsRepeater x:Name="PageNumbersRepeater" ItemsSource="{x:Bind _vm.PageNumbers, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Horizontal" Spacing="2" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Button MinWidth="36" MinHeight="36" HorizontalAlignment="Center"
                                    Click="PageNumber_Click" Content="{Binding DisplayText}"
                                    CornerRadius="18"
                                    IsEnabled="{Binding IsClickable}" />
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
                <Button Content="Next" Click="NextPage_Click" x:Name="NextBtn" />
                <Button Content="Last" Click="LastPage_Click" x:Name="LastBtn" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
